<Window x:Class="UI.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UI"
        mc:Ignorable="d"
        Title="Login" Height="190" Width="300">
    <Grid Margin="0,0,0,1" HorizontalAlignment="Center" Width="340">
        <Button x:Name="Login_btn" Content="Login" HorizontalAlignment="Left" Margin="192,118,0,0" VerticalAlignment="Top" Click="Button_Click" Width="54"/>
        <TextBox HorizontalAlignment="Left" Margin="159,28,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <PasswordBox HorizontalAlignment="Left" Margin="159,0,0,0" VerticalAlignment="Center" Width="120"/>
        <Label Content="ID" HorizontalAlignment="Left" Margin="57,28,0,0" VerticalAlignment="Top" Height="24" Width="56"/>
        <Label Content="PASSWORD" HorizontalAlignment="Left" Margin="57,0,0,0" VerticalAlignment="Center"/>

    </Grid>
</Window>
